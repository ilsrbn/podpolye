{
  "buildCommand": "ng build",
  "outputDirectory": "dist/podpolye-v2/browser",
  "headers": [
    {
      "source": "/assets/(.*).json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*).(jpg|jpeg|png|webp|gif|svg|ico|woff|woff2|ttf)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*).(js|css)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(favicon.png|robots.txt|sitemap.xml)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/((?!assets/|favicon.png|robots.txt|sitemap.xml).*)", "destination": "/index.html" }
  ]
}
